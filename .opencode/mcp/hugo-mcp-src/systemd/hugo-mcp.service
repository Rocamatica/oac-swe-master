[Unit]
Description=Hugo MCP Server
After=network.target

[Service]
Type=simple
User=jm
WorkingDirectory=/home/jm/hugo-mcp
EnvironmentFile=/home/jm/hugo-mcp/.env
ExecStart=/home/jm/hugo-mcp/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
